{
  "name": "snake-battle",
  "version": "0.1.0",
  "description": "Snake Battle - Multiplayer Snake Game with Phaser 3 and TypeScript",
  "main": "dist/server/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --exec tsx src/server/server.ts",
    "client:dev": "vite --host",
    "build": "npm run build:client && npm run build:server",
    "build:server": "esbuild src/server/server.ts --bundle --platform=node --format=esm --outfile=dist/server/server.js --packages=external --alias:@shared=./src/shared --alias:@server=./src/server",
    "build:client": "vite build",
    "start": "node dist/server/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "snake",
    "game",
    "multiplayer",
    "phaser",
    "typescript",
    "realtime"
  ],
  "engines": {
    "node": ">=24"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "phaser": "^3.55.2",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^5.59.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^8.40.0",
    "jsdom": "^29.0.2",
    "nodemon": "^3.1.14",
    "prettier": "^2.8.8",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
